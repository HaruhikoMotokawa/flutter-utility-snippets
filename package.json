{
  "name": "flutter-utility-snippets",
  "displayName": "Flutter Utility Snippets",
  "description": "A comprehensive snippet collection for Flutter and Dart development, including Riverpod, Hooks, Freezed, and test utilities. Simplify your workflow and boost productivity with frequently used code snippets.",
  "version": "1.2.0",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Snippets"
  ],
  "contributes": {
    "snippets": [
      {
        "language": "dart",
        "path": "./snippets/flutter.code-snippets"
      },
      {
        "language": "dart",
        "path": "./snippets/dart.code-snippets"
      },
      {
        "language": "dart",
        "path": "./snippets/riverpod.code-snippets"
      },
      {
        "language": "dart",
        "path": "./snippets/hooks.code-snippets"
      },
      {
        "language": "dart",
        "path": "./snippets/freezed.code-snippets"
      },
      {
        "language": "dart",
        "path": "./snippets/test.code-snippets"
      },
      {
        "language": "dart",
        "path": "./snippets/comment.code-snippets"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HaruhikoMotokawa/flutter-utility-snippets.git"
  },
  "publisher": "HaruhikoMotokawa",
  "icon": "flutter_utility_snippets.png",
  "keywords": [
    "flutter",
    "dart",
    "snippets",
    "riverpod",
    "hooks",
    "freezed",
    "test",
    "widget",
    "provider"
  ]
}
