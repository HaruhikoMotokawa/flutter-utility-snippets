            "import 'package:riverpod_annotation/riverpod_annotation.dart';",
            "",
            "part '${TM_FILENAME_BASE}.g.dart';",
            "",
            "@riverpod",
            "${1:dynamic} ${2:exampleProvider}(Ref ref) {",
            "  return ${3:null};",
            "}",
            ""
